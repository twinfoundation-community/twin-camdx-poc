# --- X-Road Playground (outbound leg: TWIN → CamDX) ----------------------
# Public read-only X-Road Playground (https://x-road.global/xroad-playground).
# Used to prove our adaptor speaks X-Road on the wire — same protocol CamDX uses.
XROAD_PLAYGROUND_BASE_URL=http://testcomss01.playground.x-road.systems
XROAD_PLAYGROUND_AUTH_USER=xrd
XROAD_PLAYGROUND_AUTH_PASS=secret

# Identity our adaptor presents as a service consumer.
# Format: INSTANCE/CLASS/MEMBER/SUBSYSTEM
# The default is the Playground's pre-registered TestClient subsystem — what
# external developers are expected to use. For a real Cambodian deployment this
# would be replaced with the subsystem registered on the Cambodian central
# server (out of PoC scope).
XROAD_CLIENT_IDENTIFIER=PLAYGROUND/COM/1234567-8/TestClient

# Provider service we're calling. The default targets the Playground's
# TestService subsystem; its REST endpoint list is returned by listMethods.
XROAD_SERVICE_IDENTIFIER=PLAYGROUND/GOV/8765432-1/TestService/PTV

# --- Kitsune (inbound leg: CamDX → TWIN, once Rodrigo enables packages) ---
TWIN_NODE_URL=https://kitsune.staging.twinnodes.com
TWIN_NODE_SERVICE_EMAIL=admin@node
TWIN_NODE_SERVICE_PASSWORD=
TWIN_NODE_ADMIN_DID=
TWIN_NODE_ADMIN_ORG_DID=
TWIN_NODE_ADMIN_SCOPE=tenant-admin

# Verification-method id under the admin DID, used to sign the citizen VC.
# Created once via POST /identity/<DID>/verification-method; the adaptor ensures
# it exists at request time (idempotent — already-exists is treated as success).
TWIN_NODE_ASSERTION_VM_ID=camdx-demo

# --- Simulator (CamDX-side mock that POSTs to /api/camdx/inbound) ---------
SIMULATOR_TARGET_URL=http://localhost:3000/api/camdx/inbound
